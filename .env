# Base URL of the SMA08 hub API (Express, see wasuwatn/SMA08). This app has
# no backend of its own — every read/write goes straight to the hub from the
# browser, authenticated with a hub-issued JWT (see src/lib/hub/client.ts).
# Point this at your hub deployment; leave empty for local dev if this app is
# served from the same origin as the hub.
VITE_API_BASE="http://localhost:4000"
